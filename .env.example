# ────────────────────────────────────────────────────────────────────────────
# Atlased — Environment Variable Reference
#
# For LOCAL DEVELOPMENT: Use .env.local (pre-configured with SQLite)
# For PRODUCTION on Pi: Copy this file to .env and use PostgreSQL settings
#
# NEVER commit .env or .env.local — both are in .gitignore.
# ────────────────────────────────────────────────────────────────────────────

# ─── Database Provider ────────────────────────────────────────────────────────
# Options: "sqlite" (local dev, file-based) or "postgresql" (production)
# LOCAL DEV: Set to "sqlite" and DATABASE_URL="file:./atlased-dev.db"
# PRODUCTION: Set to "postgresql" and provide a PostgreSQL connection string
DATABASE_PROVIDER=postgresql

# ─── Database URL ─────────────────────────────────────────────────────────────
# LOCAL DEV (SQLite): file:./atlased-dev.db
# PRODUCTION (PostgreSQL with Docker): postgresql://atlased_user:PASSWORD@db:5432/atlased
DATABASE_URL=postgresql://atlased_user:change_me_before_deploy@db:5432/atlased

# ─── PostgreSQL (only needed for Docker production) ───────────────────────────
# These three vars are used by the Postgres Docker image to initialize the DB.
POSTGRES_DB=atlased
POSTGRES_USER=atlased_user
# Use a strong random password in production: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_before_deploy

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters of random data.
# Generate with: openssl rand -base64 48
JWT_SECRET=G/eGI12j8xEZHu8IWvKijd6ssuyjCytpDHlCqf4WpPojxtTpufb+/SwOSscO7e+c
JWT_EXPIRES_IN=90d

# ─── Auth tuning ──────────────────────────────────────────────────────────────
# bcrypt cost factor. 12 is a good default (~250ms on modern hardware).
# Increase for higher security at the cost of login latency.
BCRYPT_ROUNDS=12
# Set false for HTTP-only local domains behind Nginx Proxy Manager.
# Keep true for HTTPS deployments.
COOKIE_SECURE=false

# ─── Ports ────────────────────────────────────────────────────────────────────
# Only frontend is published in production; backend and DB stay internal.
# These ports are deliberately chosen to avoid Pi-hole (80/443/53) and
# Tailscale (41641/UDP). See README for full port conflict analysis.
FRONTEND_PORT=3010
# DB_PORT is only used by docker-compose.dev.yml (exposes DB to host for local dev).
# In production (docker-compose.yml), the DB is NOT exposed to the host.
DB_PORT=5432

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to the URL the browser uses to reach the frontend.
# NEVER use "*" — this must be an exact origin.
# Local dev: http://localhost:5173 (Vite dev server)
# Production: http://localhost:3010 (or your Tailscale hostname)
CORS_ORIGIN=http://localhost:5173

# ─── Node environment ─────────────────────────────────────────────────────────
# Set to "production" in docker-compose.yml for the Pi deployment.
NODE_ENV=development
